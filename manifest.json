{
  "manifest_version": 3,
  "name": "EyeRest: 20-20-20 Screen Timer",
  "version": "1.0",
  "description": "Best eye care extension! Protect vision from digital eye strain with 20-20-20 rule reminders and guided eye exercises.",
  "permissions": [
    "alarms",
    "storage",
    "notifications",
    "tabs"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "EyeRest: 20-20-20 Eye Care"
  },
  "homepage_url": "https://eyerest.brilworks.com/",
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
